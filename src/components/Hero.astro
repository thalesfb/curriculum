---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cvLinks = {
  pt: '/refs/curriculo_thales_ferreira_pt.pdf',
  en: '/refs/resume_thales_ferreira_en.pdf',
  es: '/refs/curriculo_thales_ferreira_es.pdf',
};

const titles: Record<string, string> = {
  pt: 'Full Stack Data Engineer | Python & ML | DevOps Specialist',
  en: 'Full Stack Data Engineer | Python & ML | DevOps Specialist',
  es: 'Full Stack Data Engineer | Python & ML | Especialista DevOps',
};
---

<section class="mx-auto flex max-w-[1440px] items-center gap-20 px-20 py-25 max-xl:gap-12 max-xl:px-12 max-md:flex-col-reverse max-md:gap-8 max-md:px-6 max-md:py-12 max-md:text-center" id="hero">
  <div class="flex-1 max-w-[820px] max-md:max-w-full">
    <span class="mb-8 inline-block font-code text-xs font-medium uppercase tracking-widest text-text-secondary">
      {t('hero.greeting')}
    </span>
    <h1 class="mb-6 font-display text-5xl font-bold leading-tight text-text-primary max-xl:text-4xl max-md:text-3xl">
      {titles[lang]}
    </h1>
    <p class="mb-8 font-display text-xl font-semibold leading-relaxed text-text-secondary max-md:text-base max-md:font-normal max-md:font-body">
      {t('hero.subtitle')}
    </p>
    <div class="flex gap-4 flex-wrap max-md:justify-center">
      <a href="#projects" class="inline-flex items-center gap-2 rounded-full bg-brand-green px-6 py-3 text-sm font-bold uppercase tracking-wider text-white shadow-md hover:opacity-90 transition-opacity">
        {t('cta.portfolio')}
      </a>
      <a href={cvLinks[lang]} download class="inline-flex items-center gap-2 rounded-full border border-brand-green px-6 py-3 text-sm font-bold uppercase tracking-wider text-text-primary hover:bg-brand-green hover:text-white transition-all">
        <img src="/img/download_icon.svg" alt="" width="20" height="20" class="dark:invert">
        {t('cta.download')}
      </a>
    </div>
  </div>
  <div class="shrink-0 w-[460px] max-xl:w-[360px] max-md:w-auto">
    <div class="mx-auto h-[420px] w-[420px] overflow-hidden rounded-full bg-bg-section-alt max-xl:h-[340px] max-xl:w-[340px] max-md:h-[200px] max-md:w-[200px]">
      <img src="/img/profile_hero.png" alt="Thales Ferreira" class="h-full w-full object-cover rounded-full" width="409" height="409">
    </div>
  </div>
</section>
