---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="mx-auto max-w-[1440px] grid grid-cols-2 gap-20 px-20 py-20 max-xl:px-12 max-xl:gap-12 max-md:grid-cols-1 max-md:gap-10 max-md:px-6 max-md:py-12" id="contact">
  <div>
    <h2 class="mb-12 font-display text-4xl font-semibold text-text-primary max-md:text-3xl max-md:text-center max-md:mb-8">{t('section.contact')}</h2>
    <p class="mb-8 text-text-secondary leading-relaxed">{t('contact.text')}</p>
    <ul class="mb-8 flex flex-col gap-4">
      <li class="flex items-center gap-3 text-text-secondary">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="shrink-0"><rect x="2" y="4" width="16" height="12" rx="2" stroke="var(--color-brand-green)" stroke-width="1.5"/><path d="M2 6L10 11L18 6" stroke="var(--color-brand-green)" stroke-width="1.5"/></svg>
        <a href="mailto:thalesfb15@gmail.com" class="hover:text-brand-green transition-colors">thalesfb15@gmail.com</a>
      </li>
      <li class="flex items-center gap-3 text-text-secondary">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="shrink-0"><path d="M3 5C3 3.9 3.9 3 5 3H7L9 7L7.5 8.5C8.6 10.7 9.3 11.4 11.5 12.5L13 11L17 13V15C17 16.1 16.1 17 15 17C8 17 3 12 3 5Z" stroke="var(--color-brand-green)" stroke-width="1.5"/></svg>
        <a href="tel:+5549998048695" class="hover:text-brand-green transition-colors">+55 (49) 9 9804-8695</a>
      </li>
      <li class="flex items-center gap-3 text-text-secondary">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="shrink-0"><path d="M10 2C6.13 2 3 5.13 3 9C3 14.25 10 20 10 20C10 20 17 14.25 17 9C17 5.13 13.87 2 10 2Z" stroke="var(--color-brand-green)" stroke-width="1.5"/><circle cx="10" cy="9" r="2" stroke="var(--color-brand-green)" stroke-width="1.5"/></svg>
        <span>Santa Catarina, Brasil</span>
      </li>
    </ul>
    <div class="flex gap-3">
      <a href="https://github.com/thalesfb" target="_blank" rel="noopener noreferrer" class="flex h-11 w-11 items-center justify-center rounded-xl border border-border-line bg-bg-card text-text-secondary hover:border-brand-green hover:text-brand-green transition-all" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a href="https://linkedin.com/in/thalesfb" target="_blank" rel="noopener noreferrer" class="flex h-11 w-11 items-center justify-center rounded-xl border border-border-line bg-bg-card text-text-secondary hover:border-brand-green hover:text-brand-green transition-all" aria-label="LinkedIn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href="https://instagram.com/thalesfb15" target="_blank" rel="noopener noreferrer" class="flex h-11 w-11 items-center justify-center rounded-xl border border-border-line bg-bg-card text-text-secondary hover:border-brand-green hover:text-brand-green transition-all" aria-label="Instagram">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
    </div>
  </div>
  <form class="flex flex-col gap-4" id="contact-form">
    <input type="text" name="name" placeholder={t('contact.name')} required class="w-full rounded-xl border border-border-line bg-bg-input px-4 py-3.5 text-text-primary outline-none placeholder:text-text-placeholder focus:border-brand-green transition-colors">
    <input type="email" name="email" placeholder={t('contact.email')} required class="w-full rounded-xl border border-border-line bg-bg-input px-4 py-3.5 text-text-primary outline-none placeholder:text-text-placeholder focus:border-brand-green transition-colors">
    <textarea name="message" placeholder={t('contact.message')} rows="5" required class="w-full resize-y rounded-xl border border-border-line bg-bg-input px-4 py-3.5 text-text-primary outline-none placeholder:text-text-placeholder focus:border-brand-green transition-colors min-h-30"></textarea>
    <button type="submit" class="w-full rounded-full bg-brand-green px-6 py-3 text-sm font-bold uppercase tracking-wider text-white hover:opacity-90 transition-opacity">
      {t('cta.send')}
    </button>
  </form>
</section>
